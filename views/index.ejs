<!DOCTYPE html>
<html lang="ru">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Карьерный центр БГИТУ</title>
  <script src="https://cdn.tailwindcss.com"></script>
</head>
<body class="bg-gray-50 min-h-screen flex flex-col">

  <header class="bg-white shadow-sm">
    <div class="max-w-6xl mx-auto px-4 py-4 flex items-center justify-between">
      <h1 class="text-xl sm:text-2xl font-bold text-blue-700">Карьерный центр БГИТУ</h1>
      <a href="/admin/login" class="text-sm text-gray-500 hover:text-blue-600 transition-colors">Админ</a>
    </div>
  </header>

  <main class="flex-1 max-w-6xl mx-auto w-full px-4 py-6">

    <form method="GET" action="/" class="bg-white rounded-lg shadow-sm p-4 sm:p-6 mb-8">
      <div class="grid grid-cols-1 sm:grid-cols-3 gap-4">
        <div>
          <label for="search" class="block text-sm font-medium text-gray-700 mb-1">Поиск</label>
          <input
            type="text"
            id="search"
            name="search"
            value="<%= filters.search %>"
            placeholder="Название, компания, описание…"
            class="w-full border border-gray-300 rounded-md px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-blue-500 focus:border-blue-500"
          />
        </div>
        <div>
          <label for="employment_type" class="block text-sm font-medium text-gray-700 mb-1">Тип занятости</label>
          <select
            id="employment_type"
            name="employment_type"
            class="w-full border border-gray-300 rounded-md px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-blue-500 focus:border-blue-500"
          >
            <% employmentTypes.forEach(t => { %>
              <option value="<%= t.value %>" <%= filters.employment_type === t.value ? 'selected' : '' %>><%= t.label %></option>
            <% }) %>
          </select>
        </div>
        <div>
          <label for="location" class="block text-sm font-medium text-gray-700 mb-1">Локация</label>
          <input
            type="text"
            id="location"
            name="location"
            value="<%= filters.location %>"
            placeholder="Город или «удалённо»"
            class="w-full border border-gray-300 rounded-md px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-blue-500 focus:border-blue-500"
          />
        </div>
      </div>
      <div class="mt-4 flex justify-end">
        <button type="submit" class="bg-blue-600 text-white px-5 py-2 rounded-md text-sm font-medium hover:bg-blue-700 transition-colors">
          Искать
        </button>
      </div>
    </form>

    <% if (vacancies.length === 0) { %>
      <div class="text-center py-16">
        <p class="text-gray-500 text-lg">Ничего не найдено</p>
      </div>
    <% } else { %>
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-5">
        <% vacancies.forEach(v => { %>
          <a href="/vacancy/<%= v.id %>" class="block bg-white rounded-lg shadow-sm border border-gray-200 p-5 hover:shadow-md hover:border-blue-300 transition-all">
            <h2 class="text-lg font-semibold text-gray-900 mb-1 line-clamp-2"><%= v.title %></h2>
            <p class="text-sm text-gray-700 mb-2"><%= v.company %></p>
            <div class="flex flex-wrap gap-2 text-xs text-gray-500">
              <% if (v.location) { %>
                <span class="inline-block bg-gray-100 rounded px-2 py-0.5">📍 <%= v.location %></span>
              <% } %>
              <% if (v.employment_type) { %>
                <span class="inline-block bg-gray-100 rounded px-2 py-0.5"><%= v.employment_type %></span>
              <% } %>
              <span class="inline-block bg-gray-100 rounded px-2 py-0.5"><%= new Date(v.created_at).toLocaleDateString('ru-RU') %></span>
            </div>
          </a>
        <% }) %>
      </div>
    <% } %>
  </main>

  <footer class="bg-white border-t mt-8">
    <div class="max-w-6xl mx-auto px-4 py-4 text-center text-xs text-gray-400">
      © <%= new Date().getFullYear() %> Карьерный центр БГИТУ
    </div>
  </footer>

</body>
</html>
