<!DOCTYPE html>
<html lang="ru">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= vacancy.title %> — Центр карьеры БГИТУ</title>
  <link rel="icon" type="image/x-icon" href="/favicon.ico?v=2">
  <script src="https://cdn.tailwindcss.com"></script>
  <style>
    .page-enter { opacity: 0; transform: translateY(12px); }
    .page-visible { opacity: 1; transform: translateY(0); transition: opacity 0.4s ease, transform 0.4s ease; }
    .gallery-slide { position: relative; overflow: hidden; }
    .gallery-img { transition: transform 0.5s cubic-bezier(0.25, 0.46, 0.45, 0.94); }
    .gallery-slide:hover .gallery-img { transform: scale(1.03); }
    .gallery-dot { transition: background-color 0.3s ease, transform 0.3s ease; }
    .gallery-dot.active { background-color: #2563eb; transform: scale(1.3); }
    .fade-in { animation: fadeIn 0.5s ease forwards; }
    @keyframes fadeIn { from { opacity: 0; transform: translateY(16px); } to { opacity: 1; transform: translateY(0); } }
    .fade-in-delay-1 { animation-delay: 0.1s; opacity: 0; }
    .fade-in-delay-2 { animation-delay: 0.2s; opacity: 0; }
    #lightbox { display: none; }
    #lightbox.open { display: flex; }
    .lightbox-img { max-height: 85vh; max-width: 90vw; object-fit: contain; }
  </style>
</head>
<body class="bg-gray-50 min-h-screen flex flex-col">

  <%- include('partials/header') %>

  <main class="flex-1 max-w-3xl mx-auto w-full px-4 py-6">

    <a href="/#vacancies" class="inline-flex items-center text-sm text-blue-600 hover:text-blue-800 mb-6 transition-colors page-enter" id="pageContent">
      ← Назад к списку
    </a>

    <% if (vacancy.images && vacancy.images.length > 0) { %>
      <div class="mb-6 fade-in">
        <% if (vacancy.images.length === 1) { %>
          <div class="gallery-slide rounded-lg overflow-hidden cursor-pointer" onclick="openLightbox(0)">
            <img src="<%= vacancy.images[0].image_path %>" alt="<%= vacancy.title %>" class="gallery-img w-full h-64 sm:h-80 object-cover">
          </div>
        <% } else { %>
          <div id="gallery" class="relative">
            <div class="gallery-slide rounded-lg overflow-hidden cursor-pointer" onclick="openLightbox(currentSlide)">
              <% vacancy.images.forEach((img, i) => { %>
                <div class="gallery-item <%= i === 0 ? '' : 'hidden' %>" data-index="<%= i %>">
                  <img src="<%= img.image_path %>" alt="<%= vacancy.title %> — фото <%= i + 1 %>" class="gallery-img w-full h-64 sm:h-80 object-cover">
                </div>
              <% }) %>
            </div>
            <button onclick="prevSlide()" class="absolute left-2 top-1/2 -translate-y-1/2 bg-white/80 hover:bg-white w-10 h-10 rounded-full flex items-center justify-center shadow-md transition-all hover:scale-110">
              <svg class="w-5 h-5 text-gray-700" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7"/></svg>
            </button>
            <button onclick="nextSlide()" class="absolute right-2 top-1/2 -translate-y-1/2 bg-white/80 hover:bg-white w-10 h-10 rounded-full flex items-center justify-center shadow-md transition-all hover:scale-110">
              <svg class="w-5 h-5 text-gray-700" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/></svg>
            </button>
            <div class="flex justify-center gap-2 mt-3">
              <% vacancy.images.forEach((img, i) => { %>
                <button onclick="goToSlide(<%= i %>)" class="gallery-dot w-2.5 h-2.5 rounded-full bg-gray-300 <%= i === 0 ? 'active' : '' %>" data-dot="<%= i %>"></button>
              <% }) %>
            </div>
            <div class="flex gap-2 mt-3 overflow-x-auto pb-2">
              <% vacancy.images.forEach((img, i) => { %>
                <button onclick="goToSlide(<%= i %>)" class="flex-shrink-0 rounded-md overflow-hidden border-2 transition-all hover:opacity-80 <%= i === 0 ? 'border-blue-500 opacity-100' : 'border-transparent opacity-60' %>" data-thumb="<%= i %>">
                  <img src="<%= img.image_path %>" alt="" class="h-16 w-16 object-cover">
                </button>
              <% }) %>
            </div>
          </div>
        <% } %>
      </div>
    <% } %>

    <article class="bg-white rounded-lg shadow-sm border border-gray-200 overflow-hidden">
      <div class="p-6 sm:p-8">
        <h1 class="text-2xl sm:text-3xl font-bold text-gray-900 mb-2 fade-in"><%= vacancy.title %></h1>
        <p class="text-lg text-gray-700 mb-4 fade-in fade-in-delay-1"><%= vacancy.company %></p>

        <div class="flex flex-wrap gap-2 mb-6 text-sm fade-in fade-in-delay-2">
          <% if (vacancy.location) { %>
            <span class="inline-flex items-center bg-blue-50 text-blue-700 rounded-full px-3 py-1">📍 <%= vacancy.location %></span>
          <% } %>
          <% if (vacancy.employment_type) { %>
            <span class="inline-block bg-blue-50 text-blue-700 rounded-full px-3 py-1"><%= vacancy.employment_type %></span>
          <% } %>
          <span class="inline-block bg-gray-100 text-gray-500 rounded-full px-3 py-1"><%= new Date(vacancy.created_at).toLocaleDateString('ru-RU') %></span>
        </div>

        <% if (vacancy.description) { %>
          <section class="mb-6 fade-in fade-in-delay-2">
            <h2 class="text-sm font-semibold text-gray-500 uppercase tracking-wide mb-2">Описание</h2>
            <div class="text-gray-800 leading-relaxed whitespace-pre-line"><%= vacancy.description %></div>
          </section>
        <% } %>

        <% if (vacancy.requirements) { %>
          <section class="mb-6 fade-in fade-in-delay-2">
            <h2 class="text-sm font-semibold text-gray-500 uppercase tracking-wide mb-2">Требования</h2>
            <div class="text-gray-800 leading-relaxed whitespace-pre-line"><%= vacancy.requirements %></div>
          </section>
        <% } %>

        <% if (vacancy.contact_info) { %>
          <section class="mb-6 fade-in fade-in-delay-2">
            <h2 class="text-sm font-semibold text-gray-500 uppercase tracking-wide mb-2">Контакты</h2>
            <p class="text-gray-800"><%= vacancy.contact_info %></p>
          </section>
        <% } %>

        <div class="mt-8 flex flex-col sm:flex-row gap-3 fade-in fade-in-delay-2">
          <% if (vacancy.application_url) { %>
            <a
              href="<%= vacancy.application_url %>"
              target="_blank"
              rel="noopener noreferrer"
              class="inline-block bg-blue-600 text-white text-center px-6 py-3 rounded-md font-medium hover:bg-blue-700 transition-colors"
            >
              Откликнуться
            </a>
          <% } else { %>
            <span class="inline-block bg-gray-200 text-gray-500 text-center px-6 py-3 rounded-md font-medium cursor-not-allowed">
              Откликнуться
            </span>
          <% } %>
          <a
            href="/#vacancies"
            class="inline-block border border-blue-300 text-blue-700 text-center px-6 py-3 rounded-md font-medium hover:bg-blue-50 transition-colors"
          >
            Назад к списку
          </a>
        </div>
      </div>
    </article>

  </main>

  <div id="lightbox" class="fixed inset-0 z-50 bg-black/90 flex items-center justify-center" onclick="closeLightbox(event)">
    <button onclick="closeLightbox(event)" class="absolute top-4 right-4 text-white/70 hover:text-white transition-colors z-10">
      <svg class="w-8 h-8" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"/></svg>
    </button>
    <button onclick="lbPrev(event)" class="absolute left-2 sm:left-6 top-1/2 -translate-y-1/2 text-white/70 hover:text-white transition-all hover:scale-110 z-10">
      <svg class="w-10 h-10" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7"/></svg>
    </button>
    <button onclick="lbNext(event)" class="absolute right-2 sm:right-6 top-1/2 -translate-y-1/2 text-white/70 hover:text-white transition-all hover:scale-110 z-10">
      <svg class="w-10 h-10" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/></svg>
    </button>
    <img id="lb-img" src="" alt="" class="lightbox-img rounded-lg">
    <div id="lb-counter" class="absolute bottom-4 left-1/2 -translate-x-1/2 text-white/70 text-sm"></div>
  </div>

  <%- include('partials/footer') %>

  <script>
    let currentSlide = 0;
    const items = document.querySelectorAll('.gallery-item');
    const dots = document.querySelectorAll('[data-dot]');
    const thumbs = document.querySelectorAll('[data-thumb]');
    const total = items.length;
    const allImages = total > 0
      ? Array.from(items).map(el => el.querySelector('img').src)
      : Array.from(document.querySelectorAll('.gallery-slide img')).map(el => el.src);
    let lbIndex = 0;

    function goToSlide(n) {
      items[currentSlide].classList.add('hidden');
      dots[currentSlide].classList.remove('active');
      if (thumbs[currentSlide]) { thumbs[currentSlide].classList.remove('border-blue-500', 'opacity-100'); thumbs[currentSlide].classList.add('border-transparent', 'opacity-60'); }
      currentSlide = (n + total) % total;
      items[currentSlide].classList.remove('hidden');
      dots[currentSlide].classList.add('active');
      if (thumbs[currentSlide]) { thumbs[currentSlide].classList.add('border-blue-500', 'opacity-100'); thumbs[currentSlide].classList.remove('border-transparent', 'opacity-60'); }
    }
    function nextSlide() { goToSlide(currentSlide + 1); }
    function prevSlide() { goToSlide(currentSlide - 1); }

    function openLightbox(idx) {
      if (allImages.length === 0) return;
      lbIndex = idx;
      document.getElementById('lb-img').src = allImages[lbIndex];
      document.getElementById('lb-counter').textContent = (lbIndex + 1) + ' / ' + allImages.length;
      document.getElementById('lightbox').classList.add('open');
      document.body.style.overflow = 'hidden';
    }
    function closeLightbox(e) {
      if (e.target === document.getElementById('lightbox') || e.target.closest('button')) {
        document.getElementById('lightbox').classList.remove('open');
        document.body.style.overflow = '';
      }
    }
    function lbPrev(e) {
      e.stopPropagation();
      lbIndex = (lbIndex - 1 + allImages.length) % allImages.length;
      document.getElementById('lb-img').src = allImages[lbIndex];
      document.getElementById('lb-counter').textContent = (lbIndex + 1) + ' / ' + allImages.length;
    }
    function lbNext(e) {
      e.stopPropagation();
      lbIndex = (lbIndex + 1) % allImages.length;
      document.getElementById('lb-img').src = allImages[lbIndex];
      document.getElementById('lb-counter').textContent = (lbIndex + 1) + ' / ' + allImages.length;
    }
    document.addEventListener('keydown', e => {
      if (!document.getElementById('lightbox').classList.contains('open')) return;
      if (e.key === 'Escape') { document.getElementById('lightbox').classList.remove('open'); document.body.style.overflow = ''; }
      if (e.key === 'ArrowLeft') lbPrev(e);
      if (e.key === 'ArrowRight') lbNext(e);
    });

    requestAnimationFrame(() => document.getElementById('pageContent').classList.add('page-visible'));

    let touchStartX = 0;
    const gallery = document.getElementById('gallery');
    if (gallery) {
      gallery.addEventListener('touchstart', e => { touchStartX = e.touches[0].clientX; });
      gallery.addEventListener('touchend', e => {
        const diff = touchStartX - e.changedTouches[0].clientX;
        if (Math.abs(diff) > 50) { diff > 0 ? nextSlide() : prevSlide(); }
      });
    }
    const lb = document.getElementById('lightbox');
    let lbTouchStart = 0;
    lb.addEventListener('touchstart', e => { lbTouchStart = e.touches[0].clientX; });
    lb.addEventListener('touchend', e => {
      const diff = lbTouchStart - e.changedTouches[0].clientX;
      if (Math.abs(diff) > 50) { diff > 0 ? lbNext(e) : lbPrev(e); }
    });
  </script>

</body>
</html>
