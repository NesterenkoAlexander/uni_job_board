<!DOCTYPE html>
<html lang="ru">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Панель управления — Админ-панель</title>
  <script src="https://cdn.tailwindcss.com"></script>
</head>
<body class="bg-gray-100 min-h-screen">
  <nav class="bg-white shadow mb-6">
    <div class="container mx-auto px-4 py-3 flex items-center justify-between">
      <a href="/admin/dashboard" class="text-lg font-bold text-gray-800">Центр Карьеры БГИТУ</a>
      <div class="flex items-center gap-4">
        <a href="/admin/dashboard" class="text-gray-600 hover:text-gray-800">Вакансии</a>
        <span class="text-gray-400">|</span>
        <a href="/admin/logout" class="text-red-600 hover:text-red-800">Выйти</a>
      </div>
    </div>
  </nav>
  <div class="container mx-auto px-4">
    <h2 class="text-2xl font-bold text-gray-800 mb-4">Панель управления</h2>
    <p class="text-gray-600">Добро пожаловать, <%= adminUsername %>.</p>
    <p class="text-gray-500 mt-2">Управление вакансиями — скоро.</p>
  </div>
</body>
</html>
