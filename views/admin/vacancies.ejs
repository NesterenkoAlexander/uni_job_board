<!DOCTYPE html>
<html lang="ru">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Вакансии — Админ-панель</title>
  <script src="https://cdn.tailwindcss.com"></script>
</head>
<body class="bg-gray-100 min-h-screen">
  <nav class="bg-white shadow mb-6">
    <div class="container mx-auto px-4 py-3 flex items-center justify-between">
      <a href="/admin/dashboard" class="text-lg font-bold text-gray-800">Центр Карьеры БГИТУ</a>
      <div class="flex items-center gap-4">
        <a href="/admin/vacancies" class="text-blue-600 font-medium">Вакансии</a>
        <span class="text-gray-400">|</span>
        <span class="text-gray-600"><%= adminUsername %></span>
        <span class="text-gray-400">|</span>
        <a href="/admin/logout" class="text-red-600 hover:text-red-800">Выйти</a>
      </div>
    </div>
  </nav>
  <div class="container mx-auto px-4">
    <div class="flex items-center justify-between mb-6">
      <h2 class="text-2xl font-bold text-gray-800">Управление вакансиями</h2>
      <a href="/admin/vacancies/add" class="bg-green-600 text-white px-4 py-2 rounded-md hover:bg-green-700 transition-colors">
        + Добавить вакансию
      </a>
    </div>

    <% if (vacancies.length === 0) { %>
      <div class="bg-white rounded-lg shadow p-8 text-center">
        <p class="text-gray-500 text-lg">Вакансий пока нет.</p>
        <a href="/admin/vacancies/add" class="mt-4 inline-block text-blue-600 hover:underline">Добавить первую вакансию</a>
      </div>
    <% } else { %>
      <div class="bg-white rounded-lg shadow overflow-hidden">
        <table class="w-full">
          <thead class="bg-gray-50 border-b">
            <tr>
              <th class="px-4 py-3 text-left text-sm font-semibold text-gray-700">ID</th>
              <th class="px-4 py-3 text-left text-sm font-semibold text-gray-700">Название</th>
              <th class="px-4 py-3 text-left text-sm font-semibold text-gray-700">Компания</th>
              <th class="px-4 py-3 text-left text-sm font-semibold text-gray-700">Локация</th>
              <th class="px-4 py-3 text-left text-sm font-semibold text-gray-700">Тип</th>
              <th class="px-4 py-3 text-left text-sm font-semibold text-gray-700">Создано</th>
              <th class="px-4 py-3 text-center text-sm font-semibold text-gray-700">Действия</th>
            </tr>
          </thead>
          <tbody class="divide-y">
            <% vacancies.forEach(v => { %>
              <tr class="hover:bg-gray-50">
                <td class="px-4 py-3 text-sm text-gray-600"><%= v.id %></td>
                <td class="px-4 py-3 text-sm text-gray-800 font-medium"><%= v.title %></td>
                <td class="px-4 py-3 text-sm text-gray-600"><%= v.company %></td>
                <td class="px-4 py-3 text-sm text-gray-600"><%= v.location || '—' %></td>
                <td class="px-4 py-3 text-sm text-gray-600"><%= v.employment_type || '—' %></td>
                <td class="px-4 py-3 text-sm text-gray-500"><%= new Date(v.created_at).toLocaleDateString('ru-RU') %></td>
                <td class="px-4 py-3 text-sm text-center">
                  <a href="/admin/vacancies/edit/<%= v.id %>" class="text-blue-600 hover:underline mr-3">Редактировать</a>
                  <form method="POST" action="/admin/vacancies/delete/<%= v.id %>" class="inline" onsubmit="return confirm('Удалить вакансию «<%= v.title %>»?')">
                    <button type="submit" class="text-red-600 hover:underline">Удалить</button>
                  </form>
                </td>
              </tr>
            <% }) %>
          </tbody>
        </table>
      </div>
    <% } %>
  </div>
</body>
</html>
