<!DOCTYPE html>
<html lang="ru">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Вакансии — Админ-панель</title>
  <link rel="icon" type="image/x-icon" href="/favicon.ico?v=2">
  <script src="https://cdn.tailwindcss.com"></script>
  <style>
    .page-enter { opacity: 0; transform: translateY(12px); }
    .page-visible { opacity: 1; transform: translateY(0); transition: opacity 0.4s ease, transform 0.4s ease; }
  </style>
</head>
<body class="bg-gray-50 min-h-screen flex flex-col">
  <%- include('../partials/admin_header') %>
  <div class="flex-1 container mx-auto px-4 page-enter" id="pageContent">
    <div class="flex items-center justify-between mb-6">
      <h2 class="text-2xl font-bold text-gray-800">Управление вакансиями</h2>
      <a href="/admin/vacancies/add" class="bg-blue-600 text-white px-4 py-2 rounded-md hover:bg-blue-700 transition-colors">
        + Добавить вакансию
      </a>
    </div>

    <% if (vacancies.length === 0) { %>
      <div class="bg-white rounded-lg shadow border border-gray-200 p-8 text-center">
        <p class="text-gray-500 text-lg">Вакансий пока нет.</p>
        <a href="/admin/vacancies/add" class="mt-4 inline-block text-blue-600 hover:underline">Добавить первую вакансию</a>
      </div>
    <% } else { %>
      <div class="bg-white rounded-lg shadow border border-gray-200 overflow-hidden">
        <table class="w-full">
          <thead class="bg-blue-50 border-b border-blue-200">
            <tr>
              <th class="px-4 py-3 text-left text-sm font-semibold text-blue-800">ID</th>
              <th class="px-4 py-3 text-left text-sm font-semibold text-blue-800">Фото</th>
              <th class="px-4 py-3 text-left text-sm font-semibold text-blue-800">Название</th>
              <th class="px-4 py-3 text-left text-sm font-semibold text-blue-800">Компания</th>
              <th class="px-4 py-3 text-left text-sm font-semibold text-blue-800">Локация</th>
              <th class="px-4 py-3 text-left text-sm font-semibold text-blue-800">Тип</th>
              <th class="px-4 py-3 text-center text-sm font-semibold text-blue-800">Действия</th>
            </tr>
          </thead>
          <tbody class="divide-y divide-gray-100">
            <% vacancies.forEach(v => { %>
              <tr class="hover:bg-blue-50 transition-colors">
                <td class="px-4 py-3 text-sm text-gray-600"><%= v.id %></td>
                <td class="px-4 py-3">
                  <% if (v.primary_image) { %>
                    <img src="<%= v.primary_image %>" alt="" class="h-10 w-10 rounded object-cover">
                  <% } else { %>
                    <div class="h-10 w-10 rounded bg-blue-50 flex items-center justify-center">
                      <svg class="w-5 h-5 text-blue-300" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M4 16l4.586-4.586a2 2 0 012.828 0L16 16m-2-2l1.586-1.586a2 2 0 012.828 0L20 14m-6-6h.01M6 20h12a2 2 0 002-2V6a2 2 0 00-2-2H6a2 2 0 00-2 2v12a2 2 0 002 2z"/>
                      </svg>
                    </div>
                  <% } %>
                </td>
                <td class="px-4 py-3">
                  <a href="/vacancy/<%= v.id %>" target="_blank" class="text-sm font-medium text-blue-700 hover:text-blue-900 hover:underline"><%= v.title %></a>
                </td>
                <td class="px-4 py-3 text-sm text-gray-600"><%= v.company %></td>
                <td class="px-4 py-3 text-sm text-gray-600"><%= v.location || '—' %></td>
                <td class="px-4 py-3 text-sm text-gray-600"><%= v.employment_type || '—' %></td>
                <td class="px-4 py-3 text-sm text-center">
                  <a href="/admin/vacancies/edit/<%= v.id %>" class="text-blue-600 hover:underline mr-3">Редактировать</a>
                  <form method="POST" action="/admin/vacancies/delete/<%= v.id %>" class="inline" onsubmit="return confirm('Удалить вакансию «<%= v.title %>»?')">
                    <button type="submit" class="text-red-600 hover:underline">Удалить</button>
                  </form>
                </td>
              </tr>
            <% }) %>
          </tbody>
        </table>
      </div>
    <% } %>
  </div>

  <footer class="bg-blue-800 py-6 text-sm text-white mt-8">
    <div class="max-w-7xl mx-auto px-4 flex flex-col sm:flex-row items-center justify-between gap-2">
      <p>© <%= new Date().getFullYear() %> ФГБОУ ВО «БГИТУ». Все права защищены.</p>
      <p>Центр карьеры БГИТУ</p>
    </div>
  </footer>

  <script>
    requestAnimationFrame(() => document.getElementById('pageContent').classList.add('page-visible'));
  </script>
</body>
</html>
