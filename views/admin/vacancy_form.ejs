<!DOCTYPE html>
<html lang="ru">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= vacancy ? 'Редактирование' : 'Добавление' %> вакансии — Админ-панель</title>
  <script src="https://cdn.tailwindcss.com"></script>
</head>
<body class="bg-gray-100 min-h-screen">
  <nav class="bg-white shadow mb-6">
    <div class="container mx-auto px-4 py-3 flex items-center justify-between">
      <a href="/admin/dashboard" class="text-lg font-bold text-gray-800">Центр Карьеры БГИТУ</a>
      <div class="flex items-center gap-4">
        <a href="/admin/vacancies" class="text-blue-600 font-medium">Вакансии</a>
        <span class="text-gray-400">|</span>
        <span class="text-gray-600"><%= adminUsername %></span>
        <span class="text-gray-400">|</span>
        <a href="/admin/logout" class="text-red-600 hover:text-red-800">Выйти</a>
      </div>
    </div>
  </nav>
  <div class="container mx-auto px-4">
    <div class="flex items-center gap-3 mb-6">
      <a href="/admin/vacancies" class="text-gray-500 hover:text-gray-700">&larr; Назад</a>
      <h2 class="text-2xl font-bold text-gray-800"><%= vacancy ? 'Редактирование вакансии' : 'Новая вакансия' %></h2>
    </div>

    <form method="POST" action="<%= vacancy ? '/admin/vacancies/edit/' + vacancy.id : '/admin/vacancies/add' %>" class="bg-white rounded-lg shadow p-6 space-y-5 max-w-3xl">
      <div>
        <label for="title" class="block text-sm font-medium text-gray-700 mb-1">Название *</label>
        <input type="text" id="title" name="title" required
          value="<%= vacancy ? vacancy.title : '' %>"
          class="w-full px-3 py-2 border border-gray-300 rounded-md focus:outline-none focus:ring-2 focus:ring-blue-500"
          placeholder="Например: Frontend-разработчик">
      </div>

      <div class="grid grid-cols-2 gap-5">
        <div>
          <label for="company" class="block text-sm font-medium text-gray-700 mb-1">Компания *</label>
          <input type="text" id="company" name="company" required
            value="<%= vacancy ? vacancy.company : '' %>"
            class="w-full px-3 py-2 border border-gray-300 rounded-md focus:outline-none focus:ring-2 focus:ring-blue-500"
            placeholder="Название компании">
        </div>
        <div>
          <label for="location" class="block text-sm font-medium text-gray-700 mb-1">Локация</label>
          <input type="text" id="location" name="location"
            value="<%= vacancy ? (vacancy.location || '') : '' %>"
            class="w-full px-3 py-2 border border-gray-300 rounded-md focus:outline-none focus:ring-2 focus:ring-blue-500"
            placeholder="Например: Брянск, удалённо">
        </div>
      </div>

      <div>
        <label for="employment_type" class="block text-sm font-medium text-gray-700 mb-1">Тип занятости</label>
        <select id="employment_type" name="employment_type"
          class="w-full px-3 py-2 border border-gray-300 rounded-md focus:outline-none focus:ring-2 focus:ring-blue-500">
          <option value="">— Не указан —</option>
          <option value="Полная" <%= vacancy && vacancy.employment_type === 'Полная' ? 'selected' : '' %>>Полная</option>
          <option value="Частичная" <%= vacancy && vacancy.employment_type === 'Частичная' ? 'selected' : '' %>>Частичная</option>
          <option value="Стажировка" <%= vacancy && vacancy.employment_type === 'Стажировка' ? 'selected' : '' %>>Стажировка</option>
          <option value="Проектная работа" <%= vacancy && vacancy.employment_type === 'Проектная работа' ? 'selected' : '' %>>Проектная работа</option>
          <option value="Удалённо" <%= vacancy && vacancy.employment_type === 'Удалённо' ? 'selected' : '' %>>Удалённо</option>
        </select>
      </div>

      <div>
        <label for="description" class="block text-sm font-medium text-gray-700 mb-1">Описание</label>
        <textarea id="description" name="description" rows="5"
          class="w-full px-3 py-2 border border-gray-300 rounded-md focus:outline-none focus:ring-2 focus:ring-blue-500"
          placeholder="Описание вакансии, обязанности..."><%= vacancy ? (vacancy.description || '') : '' %></textarea>
      </div>

      <div>
        <label for="requirements" class="block text-sm font-medium text-gray-700 mb-1">Требования</label>
        <textarea id="requirements" name="requirements" rows="4"
          class="w-full px-3 py-2 border border-gray-300 rounded-md focus:outline-none focus:ring-2 focus:ring-blue-500"
          placeholder="Требования к кандидату..."><%= vacancy ? (vacancy.requirements || '') : '' %></textarea>
      </div>

      <div class="grid grid-cols-2 gap-5">
        <div>
          <label for="contact_info" class="block text-sm font-medium text-gray-700 mb-1">Контакты</label>
          <input type="text" id="contact_info" name="contact_info"
            value="<%= vacancy ? (vacancy.contact_info || '') : '' %>"
            class="w-full px-3 py-2 border border-gray-300 rounded-md focus:outline-none focus:ring-2 focus:ring-blue-500"
            placeholder="Email, телефон...">
        </div>
        <div>
          <label for="application_url" class="block text-sm font-medium text-gray-700 mb-1">Ссылка для отклика</label>
          <input type="url" id="application_url" name="application_url"
            value="<%= vacancy ? (vacancy.application_url || '') : '' %>"
            class="w-full px-3 py-2 border border-gray-300 rounded-md focus:outline-none focus:ring-2 focus:ring-blue-500"
            placeholder="https://...">
        </div>
      </div>

      <div class="flex items-center gap-3 pt-2">
        <button type="submit" class="bg-blue-600 text-white px-6 py-2 rounded-md hover:bg-blue-700 transition-colors">
          <%= vacancy ? 'Сохранить изменения' : 'Создать вакансию' %>
        </button>
        <a href="/admin/vacancies" class="text-gray-600 hover:text-gray-800">Отмена</a>
      </div>
    </form>
  </div>
</body>
</html>
