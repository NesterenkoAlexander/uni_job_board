<!DOCTYPE html>
<html lang="ru">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>500 — Внутренняя ошибка сервера</title>
  <link rel="icon" type="image/x-icon" href="/favicon.ico?v=2">
  <script src="https://cdn.tailwindcss.com"></script>
  <style>
    .page-enter { opacity: 0; transform: translateY(12px); }
    .page-visible { opacity: 1; transform: translateY(0); transition: opacity 0.4s ease, transform 0.4s ease; }
  </style>
</head>
<body class="bg-gray-50 min-h-screen flex flex-col">

  <%- include('partials/header') %>

  <main class="flex-1 flex items-center justify-center">
    <div class="text-center page-enter" id="pageContent">
      <h1 class="text-6xl font-bold text-gray-300">500</h1>
      <p class="mt-4 text-gray-600">Что-то пошло не так</p>
      <a href="/" class="mt-6 inline-block bg-blue-600 text-white px-5 py-2 rounded-md hover:bg-blue-700 transition-colors">На главную</a>
    </div>
  </main>

  <%- include('partials/footer') %>

  <script>
    requestAnimationFrame(() => document.getElementById('pageContent').classList.add('page-visible'));
  </script>
</body>
</html>
